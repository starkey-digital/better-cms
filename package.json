{
	"name": "better-cms-monorepo",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"license": "SEE LICENSE IN LICENSE",
	"author": "Starkey Digital Ltd",
	"workspaces": ["packages/*", "examples/*", "apps/*"],
	"scripts": {
		"build": "bun run --filter '*' build",
		"typecheck": "bun run --filter '*' typecheck",
		"test": "bun test",
		"format": "biome format --write .",
		"lint": "biome lint .",
		"bump": "bun scripts/bump-version.ts",
		"release": "bun run --filter better-cms build && bun scripts/publish-all.ts",
		"prepare": "husky"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.4",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.2",
		"tsdown": "^0.21.1",
		"typescript": "^5.6.3"
	},
	"packageManager": "bun@1.3.7",
	"lint-staged": {
		"*.{ts,tsx,js,jsx,mjs,cjs,json,jsonc,svelte}": ["biome check --write --no-errors-on-unmatched"]
	}
}
