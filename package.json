{
  "name": "better-cms-monorepo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "license": "SEE LICENSE IN LICENSE",
  "author": "Starkey Digital Ltd",
  "workspaces": [
    "packages/*",
    "examples/*",
    "apps/*"
  ],
  "scripts": {
    "build": "bun run --filter '*' build",
    "typecheck": "bun run --filter '*' typecheck",
    "test": "bun test",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "version": "changeset version && bun run sync:plugin",
    "sync:plugin": "bun scripts/sync-plugin-version.ts",
    "release": "bun run --filter better-cms build && bun scripts/publish-all.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@changesets/changelog-github": "^0.5.0",
    "@changesets/cli": "^2.27.10",
    "tsdown": "^0.21.1",
    "typescript": "^5.6.3"
  },
  "packageManager": "bun@1.3.7"
}
