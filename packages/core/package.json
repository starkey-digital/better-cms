{
	"name": "@better-cms/core",
	"version": "0.2.0",
	"type": "module",
	"license": "SEE LICENSE IN LICENSE",
	"author": "Starkey Digital Ltd",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/starkey-digital/better-cms.git",
		"directory": "packages/core"
	},
	"description": "better-cms core: IR, DSL, contracts, ops kernel, request handler.",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": ["dist"],
	"exports": {
		".": {
			"dev-source": "./src/index.ts",
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		},
		"./ir": {
			"dev-source": "./src/ir/index.ts",
			"types": "./dist/ir/index.d.ts",
			"default": "./dist/ir/index.js"
		},
		"./store": {
			"dev-source": "./src/store/index.ts",
			"types": "./dist/store/index.d.ts",
			"default": "./dist/store/index.js"
		},
		"./ops": {
			"dev-source": "./src/ops/index.ts",
			"types": "./dist/ops/index.d.ts",
			"default": "./dist/ops/index.js"
		},
		"./handler": {
			"dev-source": "./src/handler/index.ts",
			"types": "./dist/handler/index.d.ts",
			"default": "./dist/handler/index.js"
		},
		"./plugin": {
			"dev-source": "./src/plugin/index.ts",
			"types": "./dist/plugin/index.d.ts",
			"default": "./dist/plugin/index.js"
		}
	},
	"scripts": {
		"typecheck": "tsc --noEmit",
		"build": "tsc -p tsconfig.build.json"
	},
	"devDependencies": {
		"typescript": "^5.6.3",
		"bun-types": "^1.3.7"
	},
	"dependencies": {
		"valibot": "^1"
	},
	"publishConfig": {
		"access": "public"
	}
}
