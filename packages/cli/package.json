{
	"name": "@better-cms/cli",
	"version": "0.2.0",
	"type": "module",
	"license": "SEE LICENSE IN LICENSE",
	"author": "Starkey Digital Ltd",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/starkey-digital/better-cms.git",
		"directory": "packages/cli"
	},
	"description": "better-cms CLI (`bcms`): init, generate, mcp.",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": ["dist"],
	"bin": {
		"bcms": "./dist/bin.js"
	},
	"publishConfig": {
		"access": "public"
	},
	"exports": {
		".": {
			"dev-source": "./src/index.ts",
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		},
		"./generate": {
			"dev-source": "./src/generate.ts",
			"types": "./dist/generate.d.ts",
			"default": "./dist/generate.js"
		}
	},
	"scripts": {
		"typecheck": "tsc --noEmit",
		"build": "tsc -p tsconfig.build.json && chmod +x dist/bin.js"
	},
	"dependencies": {
		"@better-cms/core": "workspace:*",
		"jiti": "^2.4.2",
		"@modelcontextprotocol/sdk": "^1.0.4"
	},
	"devDependencies": {
		"typescript": "^5.6.3",
		"bun-types": "^1.3.7"
	}
}
