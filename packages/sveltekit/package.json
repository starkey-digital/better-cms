{
	"name": "@better-cms/sveltekit",
	"version": "0.2.0",
	"type": "module",
	"license": "SEE LICENSE IN LICENSE",
	"author": "Starkey Digital Ltd",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/starkey-digital/better-cms.git",
		"directory": "packages/sveltekit"
	},
	"description": "better-cms SvelteKit handle hook + remote-function helpers.",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": ["dist"],
	"exports": {
		".": {
			"dev-source": "./src/index.ts",
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		},
		"./server": {
			"dev-source": "./src/server.ts",
			"types": "./dist/server.d.ts",
			"default": "./dist/server.js"
		},
		"./remote": {
			"dev-source": "./src/remote.ts",
			"types": "./dist/remote.d.ts",
			"default": "./dist/remote.js"
		},
		"./auth": {
			"dev-source": "./src/auth/index.ts",
			"types": "./dist/auth/index.d.ts",
			"default": "./dist/auth/index.js"
		}
	},
	"scripts": {
		"typecheck": "tsc --noEmit",
		"build": "tsc -p tsconfig.build.json"
	},
	"dependencies": {
		"@better-cms/core": "workspace:*",
		"@better-cms/zod": "workspace:*"
	},
	"peerDependencies": {
		"@sveltejs/kit": "^2.0.0"
	},
	"devDependencies": {
		"@sveltejs/kit": "^2.20.0",
		"typescript": "^6.0.3",
		"bun-types": "^1.3.7"
	},
	"publishConfig": {
		"access": "public"
	}
}
