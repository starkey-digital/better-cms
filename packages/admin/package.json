{
	"name": "@better-cms/admin",
	"version": "0.2.0",
	"type": "module",
	"license": "SEE LICENSE IN LICENSE",
	"author": "Starkey Digital Ltd",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/starkey-digital/better-cms.git",
		"directory": "packages/admin"
	},
	"description": "better-cms drop-in admin UI (Svelte 5).",
	"svelte": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": ["dist"],
	"exports": {
		".": {
			"dev-source": "./src/lib/index.ts",
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js",
			"default": "./dist/index.js"
		},
		"./CMSAdmin.svelte": {
			"dev-source": "./src/lib/CMSAdmin.svelte",
			"svelte": "./dist/CMSAdmin.svelte",
			"types": "./dist/CMSAdmin.svelte.d.ts",
			"default": "./dist/CMSAdmin.svelte"
		}
	},
	"scripts": {
		"typecheck": "svelte-check --tsconfig ./tsconfig.json",
		"build": "svelte-package -i src/lib -o dist"
	},
	"dependencies": {
		"@better-cms/core": "workspace:*"
	},
	"peerDependencies": {
		"svelte": "^5.0.0"
	},
	"devDependencies": {
		"@sveltejs/kit": "^2.59.1",
		"@sveltejs/package": "^2.5.7",
		"@sveltejs/vite-plugin-svelte": "^7.1.1",
		"svelte": "^5.20.0",
		"svelte-check": "^4.1.0",
		"typescript": "^5.6.3"
	},
	"publishConfig": {
		"access": "public"
	}
}
