{
  "name": "better-cms",
  "version": "0.0.0",
  "type": "module",
  "license": "SEE LICENSE IN LICENSE",
  "author": "Starkey Digital Ltd",
  "repository": { "type": "git", "url": "git+https://github.com/jakestarkey/better-cms.git", "directory": "packages/better-cms" },
  "homepage": "https://github.com/jakestarkey/better-cms",
  "description": "Drop-in headless CMS for SvelteKit. BYO database, BYO storage. Single install, subpath imports.",
  "keywords": ["cms", "headless-cms", "sveltekit", "drizzle", "libsql", "content-management"],
  "sideEffects": false,
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": ["dist"],
  "exports": {
    ".": {
      "dev-source": "./src/index.ts",
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./adapters/libsql": {
      "dev-source": "./src/adapters/libsql.ts",
      "types": "./dist/adapters/libsql.d.mts",
      "default": "./dist/adapters/libsql.mjs"
    },
    "./adapters/drizzle": {
      "dev-source": "./src/adapters/drizzle.ts",
      "types": "./dist/adapters/drizzle.d.mts",
      "default": "./dist/adapters/drizzle.mjs"
    },
    "./media/s3": {
      "dev-source": "./src/media/s3.ts",
      "types": "./dist/media/s3.d.mts",
      "default": "./dist/media/s3.mjs"
    },
    "./sveltekit": {
      "dev-source": "./src/sveltekit/index.ts",
      "types": "./dist/sveltekit/index.d.mts",
      "default": "./dist/sveltekit/index.mjs"
    },
    "./sveltekit/remote": {
      "dev-source": "./src/sveltekit/remote.ts",
      "types": "./dist/sveltekit/remote.d.mts",
      "default": "./dist/sveltekit/remote.mjs"
    },
    "./admin": {
      "dev-source": "./src/admin/index.ts",
      "types": "./dist/admin/index.d.mts",
      "svelte": "./dist/admin/index.mjs",
      "default": "./dist/admin/index.mjs"
    },
    "./types": {
      "dev-source": "./src/types.ts",
      "types": "./dist/types.d.mts",
      "default": "./dist/types.mjs"
    }
  },
  "typesVersions": {
    "*": {
      "adapters/libsql": ["./dist/adapters/libsql.d.mts"],
      "adapters/drizzle": ["./dist/adapters/drizzle.d.mts"],
      "media/s3": ["./dist/media/s3.d.mts"],
      "sveltekit": ["./dist/sveltekit/index.d.mts"],
      "sveltekit/remote": ["./dist/sveltekit/remote.d.mts"],
      "admin": ["./dist/admin/index.d.mts"],
      "types": ["./dist/types.d.mts"]
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsdown",
    "dev": "tsdown --watch"
  },
  "dependencies": {
    "@better-cms/core": "workspace:*",
    "@better-cms/adapter-libsql": "workspace:*",
    "@better-cms/adapter-drizzle": "workspace:*",
    "@better-cms/media-s3": "workspace:*",
    "@better-cms/sveltekit": "workspace:*",
    "@better-cms/admin": "workspace:*"
  },
  "peerDependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "@libsql/client": "^0.14.0",
    "@modelcontextprotocol/sdk": "^1.0.4",
    "@sveltejs/kit": "^2.0.0",
    "drizzle-orm": ">=0.36.0",
    "svelte": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "@aws-sdk/client-s3": { "optional": true },
    "@aws-sdk/s3-request-presigner": { "optional": true },
    "@libsql/client": { "optional": true },
    "@modelcontextprotocol/sdk": { "optional": true },
    "@sveltejs/kit": { "optional": true },
    "drizzle-orm": { "optional": true },
    "svelte": { "optional": true }
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "bun-types": "^1.3.7",
    "tsdown": "^0.21.1",
    "typescript": "^5.6.3"
  }
}
