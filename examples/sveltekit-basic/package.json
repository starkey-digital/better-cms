{
	"name": "@better-cms-examples/sveltekit-basic",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"scripts": {
		"prepare": "svelte-kit sync || echo ''",
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"typecheck": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"cms:gen": "bunx -p @better-cms/cli bcms generate",
		"cms:mcp": "bunx -p @better-cms/cli bcms mcp",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui"
	},
	"dependencies": {
		"@better-cms/cli": "workspace:*",
		"@libsql/client": "^0.14.0",
		"better-cms": "workspace:*",
		"dotenv": "^16.4.5",
		"zod": "^4"
	},
	"devDependencies": {
		"@playwright/test": "^1.59.1",
		"@sveltejs/adapter-auto": "^4.0.0",
		"@sveltejs/kit": "^2.20.0",
		"@sveltejs/vite-plugin-svelte": "^5.0.0",
		"bun-types": "^1.3.13",
		"svelte": "^5.20.0",
		"svelte-check": "^4.1.0",
		"typescript": "^5.6.3",
		"vite": "^6.0.0"
	}
}
